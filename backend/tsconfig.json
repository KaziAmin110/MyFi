{
  "compilerOptions": {
    /* Base Options */
    "target": "ES2020",
    "module": "commonjs",
    "esModuleInterop": true,

    /* Strict Type-Checking */
    "strict": true,

    /* Project Structure */
    "rootDir": "./src",
    "outDir": "./dist",

    /* Module Resolution */
    "moduleResolution": "node",

    /* Other */
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true
  },
  "include": ["src/**/*.ts"],
  "exclude": ["node_modules"]
}
